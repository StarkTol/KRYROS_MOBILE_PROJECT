############################
# KRYROS Backend (.env)
############################
# IMPORTANT:
# - Do NOT commit the real values.
# - Copy this file to .env and fill in secrets locally or in Render.

# PostgreSQL connection string (paste your Neon URL here in your local .env)
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DATABASE_URL=

# JWT signing secret (use a long random string)
JWT_SECRET=

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://kryros.onrender.com,https://kryrosadminpanel.onrender.com

# Public frontend URL (primary user site)
FRONTEND_URL=https://kryros.onrender.com

# App port
PORT=4000
